{
    "version": "0.1.0",
    "snippets": {
        "how_save": {
            "desc": "Save text to a file / 將文字存入檔案",
            "cpp": "std::ofstream file(\"out.txt\"); file << data;",
            "python": "with open('out.txt', 'w') as f: f.write(data)",
            "rust": "std::fs::write(\"out.txt\", data)?;"
        },
        "how_read": {
            "desc": "Read content from a file / 從檔案讀取內容",
            "cpp": "std::ifstream file(\"in.txt\"); std::string str((std::istreambuf_iterator<char>(file)), std::istreambuf_iterator<char>());",
            "python": "data = open('in.txt').read()",
            "rust": "let data = std::fs::read_to_string(\"in.txt\")?;"
        },
        "how_print": {
            "desc": "Quick added snippet for how_print",
